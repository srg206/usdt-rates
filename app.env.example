# Copy to app.env (gitignored). All keys are required by config.Load().
# POSTGRES_URL user/password must match postgres.env when using docker-compose.

GRPC_ADDR=:50051
# HTTP only for K8s probes: GET /healthz/live, /healthz/ready
HEALTH_HTTP_ADDR=:8080
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/usdt_rates?sslmode=disable
MIGRATIONS_PATH=migrations

# Grinex spot depth (same host as https://grinex.io/ warmup works best for WAF)
GRINEX_DEPTH_URL=https://grinex.io/api/v1/spot/depth?symbol=usdta7a5
HTTP_CLIENT_TIMEOUT=15s
SHUTDOWN_TIMEOUT=10s

CALC_TOP_N=1
CALC_AVG_N=1
CALC_AVG_M=5

LOG_LEVEL=info
LOG_FORMAT=console
LOG_DISABLE_STACKTRACE=true
