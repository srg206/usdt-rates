GRPC_ADDR=:50051
HEALTH_HTTP_ADDR=:8080

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/usdt_rates?sslmode=disable
MIGRATIONS_PATH=migrations

GRINEX_DEPTH_URL=https://grinex.io/api/v1/spot/depth?symbol=usdta7a5
# Concurrent GetRates calls to Grinex: max simultaneous Fetch (warmup+depth) operations.
GRINEX_MAX_CONCURRENT=4

# Circuit breaker for Grinex (optional; defaults shown). Set GRINEX_CB_ENABLED=false to disable.
GRINEX_CB_ENABLED=true
GRINEX_CB_CONSECUTIVE_FAILURES=5
GRINEX_CB_OPEN_TIMEOUT=30s
GRINEX_CB_HALF_OPEN_MAX=3
# Reset failure stats in closed state every interval (0 = never).
GRINEX_CB_INTERVAL=0s

HTTP_CLIENT_TIMEOUT=15s
SHUTDOWN_TIMEOUT=10s
OTEL_COLLECTOR_URL=jaeger:4318

CALC_TOP_N=1
CALC_AVG_N=1
CALC_AVG_M=5

LOG_LEVEL=info
LOG_FORMAT=console
LOG_DISABLE_STACKTRACE=true
